      "parameters": {
        "jsCode": "// 检测乱码类型\nconst items = $input.all();\n\nreturn items.map(item => {\n  const text = item.json.textPlain || '';\n  \n  // 乱码检测逻辑\n  const hasQuestionMark = text.includes('�');\n  const hasLatin1HighBytes = /[\\x80-\\xFF]/.test(text);\n  \n  // 计算中文比例\n  const chineseChars = (text.match(/[\\u4e00-\\u9fa5]/g) || []).length;\n  const chineseRatio = text.length > 0 ? chineseChars / text.length : 0;\n  \n  let isGarbled = false;\n  let garbledType = 'none';\n  \n  if (hasQuestionMark && chineseRatio < 0.05) {\n    isGarbled = true;\n    garbledType = 'question_mark';     // 不可修复\n  } else if (hasLatin1HighBytes && chineseRatio < 0.1) {\n    isGarbled = true;\n    garbledType = 'latin1_misdecode'; // 可能可修复\n  }\n  \n  return {\n    json: {\n      ...item.json,\n      is_garbled: isGarbled,\n      garbled_type: garbledType,\n      chinese_ratio: chineseRatio\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
