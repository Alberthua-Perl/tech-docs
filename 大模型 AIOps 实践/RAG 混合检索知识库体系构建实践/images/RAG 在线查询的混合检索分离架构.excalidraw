    {
      "id": "WOGw1TYZvp7Xnu7P8ii8_",
      "type": "text",
      "x": 1771.1240323767174,
      "y": -15.249926567077637,
      "width": 538.6138916015625,
      "height": 560,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0Bv",
      "roundness": null,
      "seed": 1754672212,
      "version": 151,
      "versionNonce": 1982200585,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783408805866,
      "link": null,
      "locked": false,
      "text": "用户查询\n    │\n    ├──→ 密集检索通道（语义）\n    │         │\n    │         ├──→ ANN 快速召回 Top-N（如 100 个）\n    │         │         ↑\n    │         │         这里 N 是候选池，不是最终结果\n    │         │\n    │         └──→ 精确余弦重排 → 取 Top-K（如 20 个）\n    │                   ↑\n    │                   这里 K 是密集通道的最终输出\n    │\n    ├──→ 稀疏检索通道（BM25）\n    │         │\n    │         └──→ 直接返回 Top-K（如 20 个）\n    │                   ↑\n    │                   BM25 分数本身就是精确排序\n    │\n    └──→ [RRF 融合] → 合并两路 Top-K → 统一 Top-M（如 20 个）\n              │\n              ▼\n         [Rerank 精排] ← 这里！\n              │\n              └──→ 对 Top-M 逐个计算精确相关性分数\n              │\n              └──→ 重新排序 → 最终 Top-N（如 5 个）\n                        ↑\n                        送入 LLM 的上下文",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "用户查询\n    │\n    ├──→ 密集检索通道（语义）\n    │         │\n    │         ├──→ ANN 快速召回 Top-N（如 100 个）\n    │         │         ↑\n    │         │         这里 N 是候选池，不是最终结果\n    │         │\n    │         └──→ 精确余弦重排 → 取 Top-K（如 20 个）\n    │                   ↑\n    │                   这里 K 是密集通道的最终输出\n    │\n    ├──→ 稀疏检索通道（BM25）\n    │         │\n    │         └──→ 直接返回 Top-K（如 20 个）\n    │                   ↑\n    │                   BM25 分数本身就是精确排序\n    │\n    └──→ [RRF 融合] → 合并两路 Top-K → 统一 Top-M（如 20 个）\n              │\n              ▼\n         [Rerank 精排] ← 这里！\n              │\n              └──→ 对 Top-M 逐个计算精确相关性分数\n              │\n              └──→ 重新排序 → 最终 Top-N（如 5 个）\n                        ↑\n                        送入 LLM 的上下文",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IYat4TQGI9zvuA226sGlG",
      "type": "text",
      "x": 500.9238980993739,
      "y": 611.1500825881958,
      "width": 6.399993896484375,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
